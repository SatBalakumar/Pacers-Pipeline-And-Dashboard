// Pacers Analytics Database Schema (DBML)
// Generated from actual ETL pipeline build scripts
// Last updated: October 6, 2025

Project PacersAnalytics {
  database_type: 'SQLite'
  Note: '''
    # Pacers Analytics Database
    
    This database contains NBA data with a focus on Indiana Pacers analytics.
    
    ## Architecture
    - **Silver Layer**: Normalized source data tables (physical tables)
    - **Gold Layer**: 5 physical analytical tables + 12 SQL views
    
    ## Data Flow
    Raw Parquet → Silver Tables → Gold Tables → Gold Views → Dashboard
  '''
}

// =============================================================================
// SILVER LAYER - LOOKUP TABLES
// =============================================================================

Table venues_silver {
  venue_id integer [primary key]
  venue_name text
  venue_state text  
  venue_city text
  
  Note: "NBA arenas and venues"
}

Table teams_silver {
  team_id integer [primary key]
  team_slug text
  team_city text
  team_name text
  team_abbreviation text
  is_defunct integer
  tricode text
  
  Note: "NBA teams including historical teams"
}

Table positions_silver {
  position_id integer [primary key]
  position_code text
  
  Note: "Basketball positions (PG, SG, SF, PF, C)"
}

Table countries_silver {
  country_id integer [primary key]
  country_name text
  
  Note: "Player birth countries"
}

Table draftpicks_silver {
  draftpick_id integer [primary key]
  player_id integer [ref: > players_silver.player_id]
  draft_year integer
  draft_round integer
  draft_number integer
  
  Note: "NBA draft pick information"
}

Table gametypes_silver {
  game_type_id integer [primary key]
  game_type text
  
  Note: "Game types: Regular Season, Playoffs, Preseason"
}

Table affiliationtypes_silver {
  affiliation_id integer [primary key]
  affiliation_type text
  
  Note: "Player college/team affiliations"
}

Table dnp_reasons_silver {
  dnp_reason_code integer [primary key]
  dnp_reason_name text [not null]
  
  Note: "Did Not Play reasons (injury, rest, etc.)"
}

Table status_codes_silver {
  status_code integer [primary key]
  status_name text [not null]
  
  Note: "Game status codes (Final, In Progress, etc.)"
}

// =============================================================================
// SILVER LAYER - CORE DATA TABLES
// =============================================================================

Table players_silver {
  player_id integer [primary key]
  first_name text
  last_name text
  player_slug text
  is_active integer
  team_id integer [ref: > teams_silver.team_id]
  jersey_num integer
  position_id integer [ref: > positions_silver.position_id]
  height_inches integer
  weight integer
  birthdate text
  age integer
  country_id integer [ref: > countries_silver.country_id]
  affiliation_id integer [ref: > affiliationtypes_silver.affiliation_id]
  is_draft_pick integer
  draftpick_id integer [ref: > draftpicks_silver.draftpick_id]
  seasons_experience integer
  career_start_season integer
  career_last_season integer
  is_two_way integer
  is_ten_day integer
  season integer
  
  Note: "NBA player information and attributes"
}

Table games_silver {
  game_id integer [primary key]
  season integer
  game_datetime_est text
  home_team_id integer [ref: > teams_silver.team_id]
  away_team_id integer [ref: > teams_silver.team_id]
  venue_id integer [ref: > venues_silver.venue_id]
  home_points integer
  away_points integer
  game_type_id integer [ref: > gametypes_silver.game_type_id]
  status_code integer [ref: > status_codes_silver.status_code]
  
  Note: "NBA game results and metadata"
}

Table gameteamtotals_silver {
  game_id integer [ref: > games_silver.game_id]
  team_id integer [ref: > teams_silver.team_id]
  is_home integer
  minutes_total real
  pts integer
  fgm integer
  fga integer
  fg3m integer
  fg3a integer
  ftm integer
  fta integer
  oreb integer
  dreb integer
  reb integer
  ast integer
  stl integer
  blk integer
  tov integer
  pf integer
  pitp integer
  second_chance_pts integer
  fastbreak_pts integer
  pts_off_to integer
  
  indexes {
    (game_id, team_id) [pk]
  }
  
  Note: "Team-level statistics for each game"
}

Table playerboxscore_silver {
  game_id integer [ref: > games_silver.game_id]
  player_id integer [ref: > players_silver.player_id]
  team_id integer [ref: > teams_silver.team_id]
  starter_flag integer
  played_flag integer
  position_id integer [ref: > positions_silver.position_id]
  minutes real
  pts integer
  fgm integer
  fga integer
  fg3m integer
  fg3a integer
  ftm integer
  fta integer
  oreb integer
  dreb integer
  reb integer
  ast integer
  stl integer
  blk integer
  tov integer
  pf integer
  plusminus integer
  dnp_reason_code integer [ref: > dnp_reasons_silver.dnp_reason_code]
  
  indexes {
    (game_id, player_id) [pk]
  }
  
  Note: "Individual player statistics for each game"
}

Table pbp_silver {
  game_id integer [ref: > games_silver.game_id]
  event_num integer
  period integer
  pc_time text
  wc_time text
  event_msg_type integer
  event_action_type integer
  team_id integer [ref: > teams_silver.team_id]
  player1_id integer [ref: > players_silver.player_id]
  player2_id integer [ref: > players_silver.player_id]
  player3_id integer [ref: > players_silver.player_id]
  home_description text
  visitor_description text
  neutral_description text
  home_score integer
  away_score integer
  score_margin integer
  shot_value integer
  shot_result text
  shot_distance real
  shot_x real
  shot_y real
  shot_side text
  foul_type_code integer
  turnover_type_code integer
  is_substitution integer
  is_timeout integer
  
  indexes {
    (game_id, event_num) [pk]
  }
  
  Note: "Play-by-play data for detailed game analysis"
}

// =============================================================================
// GOLD LAYER - PHYSICAL ANALYTICAL TABLES (5 Core Tables)
// =============================================================================

Table gold_games {
  // Team-centric view: 2 rows per game (one for each team)
  game_id integer [ref: > games_silver.game_id]
  season integer
  game_datetime_est text
  venue_id integer [ref: > venues_silver.venue_id]
  game_type_id integer [ref: > gametypes_silver.game_type_id]
  status_code integer [ref: > status_codes_silver.status_code]
  
  // Team context (focus team perspective)
  team_id integer [ref: > teams_silver.team_id, note: "Focus team"]
  team_name_team text [note: "Focus team name"]
  team_city_team text [note: "Focus team city"] 
  team_abbreviation_team text [note: "Focus team abbreviation"]
  
  // Opponent context
  opp_team_id integer [ref: > teams_silver.team_id, note: "Opponent team"]
  team_name_opp text [note: "Opponent team name"]
  team_city_opp text [note: "Opponent team city"]
  team_abbreviation_opp text [note: "Opponent team abbreviation"]
  
  // Game context
  is_home integer [note: "1 if focus team is home, 0 if away"]
  
  // Team stats (from gameteamtotals_silver)
  minutes_total real
  pts integer [note: "Focus team points"]
  fgm integer
  fga integer
  fg3m integer
  fg3a integer
  ftm integer
  fta integer
  oreb integer
  dreb integer
  reb integer
  ast integer
  stl integer
  blk integer
  tov integer
  pf integer
  pitp integer
  second_chance_pts integer
  fastbreak_pts integer
  pts_off_to integer
  
  indexes {
    (game_id, team_id) [pk]
  }
  
  Note: "Team-centric games view with opponent context and stats"
}

Table gold_game_summary {
  // Game-centric view: 1 row per game
  game_id integer [primary key, ref: > games_silver.game_id]
  season integer
  game_datetime_est text
  venue_id integer [ref: > venues_silver.venue_id]
  game_type_id integer [ref: > gametypes_silver.game_type_id]
  status_code integer [ref: > status_codes_silver.status_code]
  
  // Home team info
  home_team_id integer [ref: > teams_silver.team_id]
  home_team_name text
  home_team_city text
  home_team_abbreviation text
  home_points integer
  
  // Away team info  
  away_team_id integer [ref: > teams_silver.team_id]
  away_team_name text
  away_team_city text
  away_team_abbreviation text
  away_points integer
  
  // Calculated fields
  point_differential integer [note: "home_points - away_points"]
  total_points integer [note: "home_points + away_points"]
  
  Note: "Game-centric summary with home/away team details"
}

Table gold_player_info {
  // Enhanced player information with joins
  player_id integer [primary key, ref: > players_silver.player_id]
  first_name text
  last_name text
  player_slug text
  is_active integer
  team_id integer [ref: > teams_silver.team_id]
  jersey_num integer
  position_id integer [ref: > positions_silver.position_id]
  height_inches integer
  weight integer
  birthdate text
  age integer
  country_id integer [ref: > countries_silver.country_id]
  affiliation_id integer [ref: > affiliationtypes_silver.affiliation_id]
  is_draft_pick integer
  draftpick_id integer [ref: > draftpicks_silver.draftpick_id]
  seasons_experience integer
  career_start_season integer
  career_last_season integer
  is_two_way integer
  is_ten_day integer
  season integer
  
  // Joined fields from related tables
  team_name_team text [note: "From teams_silver"]
  team_city_team text [note: "From teams_silver"]
  team_abbreviation_team text [note: "From teams_silver"]
  position_code text [note: "From positions_silver"]
  country_name text [note: "From countries_silver"]
  draft_year integer [note: "From draftpicks_silver"]
  draft_round integer [note: "From draftpicks_silver"]
  draft_number integer [note: "From draftpicks_silver"]
  
  // Calculated fields
  full_name text [note: "first_name + last_name"]
  
  Note: "Complete player profiles with all related information"
}

Table gold_player_boxscore {
  // Enhanced player boxscores with game and team context
  game_id integer [ref: > games_silver.game_id]
  player_id integer [ref: > players_silver.player_id]
  team_id integer [ref: > teams_silver.team_id]
  starter_flag integer
  played_flag integer
  position_id integer [ref: > positions_silver.position_id]
  minutes real
  pts integer
  fgm integer
  fga integer
  fg3m integer
  fg3a integer
  ftm integer
  fta integer
  oreb integer
  dreb integer
  reb integer
  ast integer
  stl integer
  blk integer
  tov integer
  pf integer
  plusminus integer
  dnp_reason_code integer [ref: > dnp_reasons_silver.dnp_reason_code]
  
  // Game context (from games_silver)
  season integer
  game_datetime_est text
  home_team_id integer [ref: > teams_silver.team_id]
  away_team_id integer [ref: > teams_silver.team_id]
  
  // Calculated game context
  is_home integer [note: "1 if player's team was home"]
  opp_team_id integer [ref: > teams_silver.team_id, note: "Opponent team ID"]
  
  // Team context (from teams_silver)
  team_name_team text [note: "Player's team name"]
  team_abbreviation_team text [note: "Player's team abbreviation"]
  team_name_opp text [note: "Opponent team name"]
  team_abbreviation_opp text [note: "Opponent team abbreviation"]
  
  // Position context
  position_code text [note: "From positions_silver"]
  
  // Calculated shooting percentages
  fg_pct real [note: "Field goal percentage (calculated)"]
  fg3_pct real [note: "Three-point percentage (calculated)"]
  ft_pct real [note: "Free throw percentage (calculated)"]
  
  indexes {
    (game_id, player_id) [pk]
  }
  
  Note: "Enhanced player boxscores with full game and team context"
}

Table gold_player_averages {
  // Season aggregations for players
  player_id integer [ref: > players_silver.player_id]
  season integer
  
  // Aggregated stats
  gp integer [note: "Games played (count)"]
  mpg real [note: "Minutes per game (mean)"]
  ppg real [note: "Points per game (mean)"]
  rpg real [note: "Rebounds per game (mean)"]
  apg real [note: "Assists per game (mean)"] 
  spg real [note: "Steals per game (mean)"]
  bpg real [note: "Blocks per game (mean)"]
  tpg real [note: "Turnovers per game (mean)"]
  
  // Season totals for shooting calculations
  fgm_total integer [note: "Total field goals made"]
  fga_total integer [note: "Total field goals attempted"]
  fg3m_total integer [note: "Total 3-pointers made"]
  fg3a_total integer [note: "Total 3-pointers attempted"]
  ftm_total integer [note: "Total free throws made"]
  fta_total integer [note: "Total free throws attempted"]
  
  // Season shooting percentages
  fg_pct real [note: "Season field goal percentage"]
  three_pct real [note: "Season three-point percentage"]
  ft_pct real [note: "Season free throw percentage"]
  
  indexes {
    (player_id, season) [pk]
  }
  
  Note: "Season-aggregated player statistics and shooting percentages"
}

// =============================================================================
// GOLD LAYER - SQL VIEWS (12 Analytical Views)
// =============================================================================

Table gold_preseason_games {
